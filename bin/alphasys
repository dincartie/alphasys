# VMID 105 HQ-CLI
ns_hq_client() {
    info "network_setup: ${MACHINE_ID}"

    info "Setting hostname: hq-cli.au-team.irpo"
    run hostnamectl set-hostname hq-cli.au-team.irpo

    warn "HQ-CLI uses DHCP. Configure ens19 via the System Control Center GUI:"
    warn "  Main Menu - Show Applications - System Control Center"
    warn "  - Network - Ethernet Interfaces - Configuration: Use DHCP"

    ok "105 VMID hostname set. Manual DHCP configuration required on the GUI."
}

# Dispatcher
run_network_setup() {
    info "module: network_setup"
    case "${VMID_ROLE[$MACHINE_ID]}" in
        isp)    ns_isp       ;;
        hq-rtr) ns_hq_router ;;
        br-rtr) ns_br_router ;;
        hq-srv) ns_hq_server ;;
        br-srv) ns_br_server ;;
        hq-cli) ns_hq_client ;;
    esac
}

# MODULE: network_admin (not yet implemented)
run_network_admin() {
    info "module: network_admin"
    warn "network_admin: no tasks implemented yet."
}

# MODULE: hybrid (not yet implemented)
run_hybrid() {
    info "module: hybrid"
    warn "hybrid: no tasks implemented yet."
}

main() {
    if [ $# -eq 0 ]; then show_help; exit 0; fi

    parse_args "$@"
    validate_args

    : > /root/alphasys_result.log

    local role="${VMID_ROLE[$MACHINE_ID]}"
    local hostname="${VMID_HOSTNAME[$MACHINE_ID]}"

    _p " alphasys starting"
    _p " Machine ID : ${MACHINE_ID}  (${role}  /  ${hostname})"

    case "$MODULE" in
        network_setup) run_network_setup ;;
        network_admin) run_network_admin ;;
        hybrid)        run_hybrid        ;;
    esac

    if $HAD_ERROR; then
        _p "failed. (see /root/alphasys_result.log for details)"
        if ! $VERBOSE; then echo "alphasys: failed."; fi
        exit 1
    else
        _p "success."
        if ! $VERBOSE; then echo "alphasys: success."; fi
        exit 0
    fi
}

main "$@"
